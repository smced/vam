sudo docker exec -i $(sudo docker ps --filter "name=AssetManager_postgres" --format "{{.ID}}") \
  psql -U 'Ap1D4t4b4s3%4dm1nUs3rn4m3' -d vam --csv \
  -c "
WITH props AS (
  SELECT
    \"AssetId\",
    \"PropertyName\",
    \"Value\"#>>'{}'  AS val
  FROM \"PropertyValue\"
  WHERE \"PropertyName\" IN (
    'ADI - Network - Hostname',
    'Lifecycle - Logical Location',
    'Lifecycle - Logical Location - Site'
  )
)
SELECT
  \"AssetId\",
  MAX(CASE WHEN \"PropertyName\" = 'ADI - Network - Hostname'            THEN val END) AS \"Hostname\",
  MAX(CASE WHEN \"PropertyName\" = 'Lifecycle - Logical Location'        THEN val END) AS \"LogicalLocation\",
  MAX(CASE WHEN \"PropertyName\" = 'Lifecycle - Logical Location - Site' THEN val END) AS \"LogicalLocationSite\"
FROM props
GROUP BY \"AssetId\"
ORDER BY \"AssetId\"
" | tee ~/logical_location_list.csv
